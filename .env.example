# Admin API (for authentication and admin operations)
VITE_API_URL=http://localhost:5002/api/v1

# Client API (for WebSocket predictions and user operations)
VITE_CLIENT_API_URL=http://localhost:5001/api/v1

# Live Engine API (for historical candles and real-time data)
VITE_LIVE_ENGINE_URL=http://localhost:8001

